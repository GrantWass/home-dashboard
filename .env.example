# Strava API Credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Strava Athlete IDs for you and your roommates
# Find athlete IDs by visiting strava.com/athletes/YOUR_ID or via the API
STRAVA_ATHLETE_IDS=12345678,87654321,11223344

# Strava Athlete Display Names (comma-separated, matching order of IDs)
STRAVA_ATHLETE_NAMES=You,Roommate1,Roommate2

# Weather API (OpenWeatherMap - free tier works)
# Get from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_CITY=San Francisco
WEATHER_COUNTRY=US
WEATHER_UNITS=imperial

# Server config
PORT=3000

# Notes file path (optional, defaults to ./notes.txt)
NOTES_FILE=./notes.txt
